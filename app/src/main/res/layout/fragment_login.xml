<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_player_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="64dp"
        android:paddingBottom="32dp">

        <!-- Logo / Ícone do app -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Logo"
            android:scaleType="fitCenter" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="GmodScore"
            android:textColor="@color/player_text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="40dp"
            android:text="Faça login para continuar"
            android:textColor="@color/player_text_secondary"
            android:textSize="14sp" />

        <!-- Card de Login -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/player_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/player_surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Abas Login / Cadastro -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:tabIndicatorColor="@color/player_accent"
                    app:tabSelectedTextColor="@color/player_accent"
                    app:tabTextColor="@color/player_text_secondary"
                    app:tabBackground="@android:color/transparent">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cadastrar" />
                </com.google.android.material.tabs.TabLayout>

                <!-- Campo: Usuário -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Usuário"
                    app:boxStrokeColor="@color/player_accent"
                    app:hintTextColor="@color/player_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/player_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Senha -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Senha"
                    app:boxStrokeColor="@color/player_accent"
                    app:hintTextColor="@color/player_text_secondary"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/player_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Confirmar Senha (só no cadastro) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutConfirmPassword"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Confirmar senha"
                    android:visibility="gone"
                    app:boxStrokeColor="@color/player_accent"
                    app:hintTextColor="@color/player_text_secondary"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/player_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mensagem de erro -->
                <TextView
                    android:id="@+id/txtErro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:textColor="#FF5252"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Botão principal -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAcao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Entrar"
                    app:backgroundTint="@color/player_accent"
                    app:cornerRadius="18dp" />

                <!-- Loading -->
                <ProgressBar
                    android:id="@+id/progressLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Entrar como Visitante -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVisitante"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Entrar como visitante"
            app:iconGravity="textStart"
            app:icon="@drawable/ic_person"
            app:iconTint="@color/player_text_secondary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>