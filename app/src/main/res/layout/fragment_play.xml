<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_player_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Jogar"
            android:textColor="@color/player_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Card: Status do servidor -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/player_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/player_surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Linha: nome do servidor + status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SERVIDOR"
                            android:textAllCaps="true"
                            android:textColor="@color/player_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtServidorNome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/player_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="GmodScore BR #1" />
                    </LinearLayout>

                    <!-- Badge Online/Offline -->
                    <TextView
                        android:id="@+id/txtServidorStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="● ONLINE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#1DB954"
                        android:background="@drawable/bg_avatar_placeholder"
                        tools:text="● ONLINE" />
                </LinearLayout>

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/player_surface_border" />

                <!-- Infos: Mapa + Modo + Jogadores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Mapa atual -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗺️"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtMapaAtual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/player_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="gm_construct" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MAPA"
                            android:textAllCaps="true"
                            android:textColor="@color/player_text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Modo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚔️"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtModoAtual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/player_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="TDM" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MODO"
                            android:textAllCaps="true"
                            android:textColor="@color/player_text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Jogadores online -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtJogadoresOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/player_accent"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="5 / 16" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PLAYERS"
                            android:textAllCaps="true"
                            android:textColor="@color/player_text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Seu rank rápido -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/player_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/player_surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEU RANKING"
                        android:textAllCaps="true"
                        android:textColor="@color/player_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtPlayRankPosicao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/player_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="#2 Global" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PONTOS"
                        android:textAllCaps="true"
                        android:textColor="@color/player_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtPlayPontos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/player_accent"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="2100" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="K/D"
                        android:textAllCaps="true"
                        android:textColor="@color/player_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/txtPlayKD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/player_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="2.67" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÃO JOGAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJogar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:text="🎮  JOGAR AGORA"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/player_accent"
            app:cornerRadius="20dp" />

        <!-- IP para conectar manualmente -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/player_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/player_surface_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Conectar manualmente"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtServerIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/player_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="127.0.0.1:27015" />

                <!-- Copiar IP -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopiarIp"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:icon="@android:drawable/ic_menu_share"
                    app:iconTint="@color/player_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Partidas ativas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="12dp"
            android:text="Partidas em andamento"
            android:textColor="@color/player_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPartidasAtivas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_partida_ativa" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>